# PureTrans backend production environment example.
# Copy the real values to /etc/puretrans/backend.env on the server.

PURETRANS_WECHAT_APP_ID=wx_your_app_id
PURETRANS_WECHAT_APP_SECRET=your_wechat_app_secret
PURETRANS_AUTH_STATE_SIGNING_KEY=replace_with_a_long_random_string_for_auth_state
PURETRANS_SESSION_SIGNING_KEY=replace_with_a_different_long_random_string_for_session
PURETRANS_SESSION_TTL_SECONDS=7200
PURETRANS_CORS_ORIGINS=capacitor://localhost,http://localhost
